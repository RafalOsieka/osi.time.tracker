{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "osi-time-tracker",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "type-check": "nuxt typecheck",
    "test:unit": "vitest --project unit",
    "test:e2e": "vitest --project e2e",
    "test:e2e:dev": "cross-env NUXT_TEST_DEV=1 vitest --project e2e",
    "test:nuxt": "vitest --project nuxt",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-security": "^2.6.0",
    "postgres": "^3.4.9",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/i18n": "^10.4.0",
    "@primevue/nuxt-module": "^4.5.5",
    "@types/node": "^25.9.4",
    "@typescript-eslint/parser": "^8.62.0",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "playwright-core": "^1.61.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "author": "Rafal Osieka",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RafalOsieka/osi.time.tracker.git"
  },
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  }
}
