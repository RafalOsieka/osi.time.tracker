# PostgreSQL connection string used by the server-side Drizzle client and migrations.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
# NOTE: Requires PostgreSQL >= 18 (for native uuidv7() support).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/osi_time_tracker

# Optional bootstrap user credentials to seed the initial user during migrate step.
# If set, the migrator creates the user (email normalized to lowercase, password hashed).
BOOTSTRAP_USER_EMAIL=admin@example.com
BOOTSTRAP_USER_PASSWORD=change-me-to-a-random-secure-password

# Secret used by nuxt-auth-utils to seal the session cookie.
# MUST be at least 32 characters. Generate one with e.g. `openssl rand -base64 32`.
# Required in production (startup fails fast if missing).
NUXT_SESSION_PASSWORD=change-me-to-a-random-32-plus-char-secret

# Optional overrides for the Docker Compose `db` service (docker-compose.yml).
# Compose auto-loads this file; uncomment to override the defaults below.
# Keep these in sync with DATABASE_URL above.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=osi_time_tracker
# POSTGRES_PORT=5432

# Optional overrides for the Docker Compose `pgadmin` service (docker-compose.yml).
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=admin
# PGADMIN_PORT=8080
